<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.dakota.usage-report</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>/Users/dakota/dakota/scripts/run_usage_report.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>0</integer>
    <key>Minute</key>
    <integer>5</integer>
  </dict>
  <key>WorkingDirectory</key>
  <string>/Users/dakota/dakota</string>
  <key>StandardOutPath</key>
  <string>/Users/dakota/dakota/logs/usage-report.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/dakota/dakota/logs/usage-report.stderr.log</string>
</dict>
</plist>
